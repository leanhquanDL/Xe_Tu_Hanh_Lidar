<launch>
  <include file="$(find my_bot)/launch/run_robot.launch"/>

  <node pkg="map_server" name="map_server" type="map_server" args="$(find my_bot)/maps/my_map.yaml"/>

  <node pkg="amcl" type="amcl" name="amcl" output="screen">
    <param name="odom_frame_id" value="odom"/>
    <param name="base_frame_id" value="base_link"/>
    <param name="global_frame_id" value="map"/>
    <param name="scan_topic" value="scan"/>
    
    <param name="min_particles" value="500"/>
    <param name="max_particles" value="3000"/>
    
    <param name="update_min_d" value="0.1"/>
    <param name="update_min_a" value="0.1"/>

    <param name="odom_model_type" value="diff-corrected"/>

    <param name="odom_alpha1" value="5.0"/> 

    <param name="odom_alpha2" value="3.0"/> 

    <param name="odom_alpha3" value="3.0"/> 

    <param name="odom_alpha4" value="5.0"/>

  </node>

  <node pkg="move_base" type="move_base" respawn="false" name="move_base" output="screen">
    <rosparam file="$(find my_bot)/param/common_costmap_params.yaml" command="load" ns="global_costmap" /> 
    <rosparam file="$(find my_bot)/param/common_costmap_params.yaml" command="load" ns="local_costmap" />
    <rosparam file="$(find my_bot)/param/local_costmap_params.yaml" command="load" />
    <rosparam file="$(find my_bot)/param/global_costmap_params.yaml" command="load" /> 
    <rosparam file="$(find my_bot)/param/base_local_planner_params.yaml" command="load" />
    
    <param name="planner_frequency" value="1.0"/> 
    
    <param name="controller_frequency" value="5.0"/> 
    
    <param name="recovery_behavior_enabled" value="true"/> 
    <param name="clearing_rotation_allowed" value="true"/>
  </node>

  <node pkg="rviz" type="rviz" name="rviz" required="true"/>
</launch>

